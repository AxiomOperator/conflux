# ── Conflux Docker Environment ──────────────────────────────────────────────
# Copy this to .env and fill in real values before running docker-compose up
#
# When all services run via docker-compose, internal URLs use service names.
# If running external services separately on 192.1.3.41, change the hostnames.

# ── Environment ────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PUBLIC_BASE_URL=https://conflux.example.com
DATA_GUARD_ENABLED=false

# ── Database ────────────────────────────────────────────────
# Service name: db (mapped to conflux-postgres container)
POSTGRES_USER=Postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nexusharness
# Full URL is composed by docker-compose using the vars above — do not set manually here.

# ── Cache / Queue ────────────────────────────────────────────
# Service name: dragonfly
DRAGONFLY_URL=redis://dragonfly:6379
DRAGONFLY_PASSWORD=

# ── Vector Store ─────────────────────────────────────────────
# Service name: qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_DOCUMENTS=conflux_documents
QDRANT_COLLECTION_MEMORY=conflux_memory
QDRANT_COLLECTION_SKILLS=conflux_skills

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_BASE_URL=http://192.1.3.41:8082/v1
EMBEDDING_API_KEY=

# ── SearXNG ──────────────────────────────────────────────────
# Service name: searxng
SEARXNG_URL=http://searxng:8080
SEARXNG_TIMEOUT_MS=15000

# ── Voice / STT ───────────────────────────────────────────────
# Service name: whisper
WHISPER_BASE_URL=http://whisper:8000
WHISPER_MODEL=base

# ── LLM Providers ────────────────────────────────────────────
OLLAMA_BASE_URL=http://192.1.3.41:11434/v1
OLLAMA_DEFAULT_MODEL=

VLLM_BASE_URL=
VLLM_DEFAULT_MODEL=

LLAMACPP_BASE_URL=
LLAMACPP_DEFAULT_MODEL=

LMSTUDIO_BASE_URL=
LMSTUDIO_DEFAULT_MODEL=

# ── Auth (generate strong random values) ────────────────────
# openssl rand -base64 32
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxx
API_KEY_PEPPER=change-me-min-32-chars-xxxxxxxxxx
JWT_EXPIRY=7d

# ── Microsoft Entra ID (Azure AD) SSO ───────────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://conflux.example.com
NEXTAUTH_API_URL=http://conflux-api:8001
INTERNAL_API_SECRET=generate-with-openssl-rand-base64-32

# ── Telegram (optional) ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MODE=polling

# ── Filesystem (inside container) ────────────────────────────
CONFLUX_HOME=/app/.conflux
SKILLS_DIR=/app/skills
WORKSPACE_ROOT=/app/workspace

# ── API Server ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ── UI Build Arg (baked in at docker build time) ─────────────
# Only needed if your UI makes direct browser → API calls
NEXT_PUBLIC_API_URL=
