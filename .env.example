# ── Environment ────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PUBLIC_BASE_URL=http://localhost:3000

# Blocks destructive tool actions in dev
DATA_GUARD_ENABLED=false

# ── Database (Postgres) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/conflux_core

# ── Cache / Queue (DragonflyDB — Redis-compatible) ──────────
DRAGONFLY_URL=redis://localhost:6379
DRAGONFLY_PASSWORD=

# ── Vector Store (Qdrant) ───────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_DOCUMENTS=conflux_documents
QDRANT_COLLECTION_MEMORY=conflux_memory
QDRANT_COLLECTION_SKILLS=conflux_skills

# ── Embeddings (OpenAI-compatible endpoint) ─────────────────
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_MODEL=Qwen3-Embedding-8B-f16.gguf
EMBEDDING_BASE_URL=http://localhost:8082/v1
EMBEDDING_API_KEY=

# ── SearXNG ─────────────────────────────────────────────────
SEARXNG_URL=http://localhost:8080
SEARXNG_TIMEOUT_MS=15000

# ── SkillsMP Marketplace ─────────────────────────────────────
SKILLS_API_KEY=sk_live_...

# ── Voice / STT (faster-whisper-server) ─────────────────────
WHISPER_BASE_URL=http://localhost:8000
WHISPER_MODEL=base

# ── LLM Providers ───────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_DEFAULT_MODEL=qwen3.5:122b

VLLM_BASE_URL=http://localhost:8000/v1
VLLM_DEFAULT_MODEL=qwen35

LLAMACPP_BASE_URL=http://localhost:8080/v1
LLAMACPP_DEFAULT_MODEL=

LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_DEFAULT_MODEL=

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=change-me-min-32-chars-xxxxxxxxxx
API_KEY_PEPPER=change-me-min-32-chars-xxxxxxxxxx
JWT_EXPIRY=7d

# ── Microsoft Entra ID (Azure AD) SSO ──────────────────────
AZURE_AD_CLIENT_ID=your-azure-app-client-id
AZURE_AD_CLIENT_SECRET=your-azure-app-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id
NEXTAUTH_SECRET=generate-a-strong-random-secret
NEXTAUTH_URL=https://conflux.example.com
NEXTAUTH_API_URL=http://localhost:3000/v1
INTERNAL_API_SECRET=generate-a-strong-random-secret

# ── Telegram Channel ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_MODE=polling

# ── Filesystem ──────────────────────────────────────────────
CONFLUX_HOME=./.conflux
SKILLS_DIR=./skills
WORKSPACE_ROOT=./workspace

# ── API Server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000
